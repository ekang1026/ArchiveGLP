# Copy to .env.local (gitignored) and fill in values from
# Supabase project -> Settings -> API.

# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# SERVER ONLY - never prefix with NEXT_PUBLIC. This key bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Firm identity for this deployment (single-tenant for now).
# Must match the FirmId regex: ^firm_[a-z0-9]{6,32}$
FIRM_ID=firm_archdev001

# Admin API key for POST /api/admin/pending-enrollments.
# Generate with: `openssl rand -base64 36`
ADMIN_API_KEY=generate-a-random-48-char-string-here

# Signed-cookie session secret (for the mock dashboard login until we
# swap to Supabase Auth). 32+ chars. Generate with openssl rand -base64 32.
SESSION_SECRET=at-least-32-bytes-of-entropy-here-go-generate

# Optional; defaults to http://127.0.0.1:3000 in dev
# APP_BASE_URL=https://your-vercel-deploy.vercel.app
