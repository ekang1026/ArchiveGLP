{
  "name": "@archiveglp/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:ingest && pnpm build:archiver && pnpm build:heartbeat && pnpm build:enroll && pnpm build:authorizer",
    "build:ingest": "esbuild src/ingest.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/ingest.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "build:archiver": "esbuild src/archiver.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/archiver.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "build:heartbeat": "esbuild src/heartbeat.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/heartbeat.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "build:enroll": "esbuild src/enroll.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/enroll.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "build:authorizer": "esbuild src/authorizer.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/authorizer.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "lint": "biome check src"
  },
  "dependencies": {
    "@archiveglp/schema": "workspace:*",
    "@aws-sdk/client-rds-data": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
