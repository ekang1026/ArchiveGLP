# Copy to .env.local (gitignored) and fill in values. See DEV_QUICKSTART.md
# at the repo root for a one-command bootstrap that generates this file.

# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# SERVER ONLY - never prefix with NEXT_PUBLIC. This key bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Firm identity for this deployment (single-tenant for now).
# Must match the FirmId regex: ^firm_[a-z0-9]{6,32}$
FIRM_ID=firm_archdev001

# Admin API key for POST /api/admin/pending-enrollments (shared
# header-auth secret, not a supervisor cookie).
# Generate with: openssl rand -base64 36
ADMIN_API_KEY=generate-a-random-48-char-string-here

# Signed-cookie session secret for the MVP mock dashboard login.
# 32+ chars. Generate with: openssl rand -base64 48
SESSION_SECRET=at-least-32-bytes-of-entropy-here-go-generate

# --- Remediation command signing (required) -------------------------
#
# The backend ECDSA P-256 keypair the dashboard uses to sign every
# pending_command row. Agents verify these signatures before executing
# remediation actions — a MITM injecting `revoke` / `restart_machine`
# into a poll response is refused because the payload isn't signed.
#
# Generate once per deployment:
#   openssl genpkey -algorithm EC -pkeyopt ec_paramgen_curve:P-256 \
#       -outform DER -out /tmp/cmd.key
#   base64 -w0 /tmp/cmd.key   # paste as COMMAND_SIGNING_PRIVATE_KEY_B64
#   rm /tmp/cmd.key
#
# Rotate by changing KEY_ID + regenerating the key + re-enrolling
# every device. Agents refuse commands whose key_id doesn't match
# the one they recorded at enrollment.
COMMAND_SIGNING_KEY_ID=local-1
COMMAND_SIGNING_PRIVATE_KEY_B64=paste-the-base64-DER-PKCS8-here

# --- Step-up re-auth for destructive commands (required) ------------
#
# Shared password the supervisor must re-enter to unlock
# revoke / rotate_key / restart_machine. Without this set, all
# destructive actions fail closed with 503 — this is intentional.
# In production, swap this for WebAuthn / TOTP via /api/admin/step-up.
SUPERVISOR_STEPUP_PASSWORD=pick-anything-for-local-dev

# Optional; defaults to http://127.0.0.1:3001 in dev
# APP_BASE_URL=https://your-vercel-deploy.vercel.app
